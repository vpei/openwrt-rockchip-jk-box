
config aria2 'main'
	option bt_enable_lpd 'true'
	option enable_dht 'true'
	option follow_torrent 'true'
	option save_session_interval '30'
	option rpc_secure 'false'
	option enable_proxy '0'
	option enable_dht6 'false'
	option enable_peer_exchange 'true'
	option peer_id_prefix 'root'
	option rpc_auth_method 'token'
	option check_certificate 'false'
	option max_overall_upload_limit '10M'
	option max_upload_limit '5M'
	option bt_max_open_files '200'
	option bt_max_peers '0'
	option bt_request_peer_speed_limit '100K'
	option seed_ratio '100'
	option seed_time '600000'
	option enable_logging '1'
	option log_level 'debug'
	option file_allocation 'falloc'
	list extra_settings 'netrc-path=/tmp/.netrc'
	option user 'root'
	option dir '/mnt/sda1/alist/aria2'
	option config_dir '/mnt/sda1/alist'
	option log '/mnt/sda1/alist/aria2.log'
	option rpc_secret 'asdfadsf'
	option enabled '0'

