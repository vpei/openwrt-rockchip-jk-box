
config xfrp 'init'
	option loglevel '7'
	option disabled '1'

config xfrpc 'common'
	option server_port '7000'
	option server_addr 'frp1.freefrp.net'
	option token 'freefrp.net'

config xfrpc 'frp1_freefrp_net_http'
	option local_ip '192.168.192.8'
	option type 'http'
	option local_port '5245'
	option custom_domains 'frp1.freefrp.net'

config xfrpc 'frp1_freefrp_net_https'
	option local_ip '192.168.192.12'
	option type 'https'
	option local_port '5245'
	option custom_domains 'frp1.freefrp.net'

config xfrpc 'vpnn_vmess_com_http'
	option type 'http'
	option local_port '80'
	option custom_domains 'vpnn.vmess.com'
	option local_ip '192.168.8.5'

config xfrpc 'vpnn_vmess_com_https'
	option type 'https'
	option local_port '443'
	option custom_domains 'vpnn.vmess.com'
	option local_ip '192.168.8.5'

